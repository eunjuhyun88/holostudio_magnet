{
  "name": "mesh-autoresearch-visualizer",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite",
    "dev:svelte": "vite",
    "dev:react": "vite --config vite.react.config.ts",
    "build": "vite build",
    "build:svelte": "vite build",
    "build:react": "vite build --config vite.react.config.ts",
    "preview": "vite preview",
